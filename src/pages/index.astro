---
import { ArrowRight, CheckCircle2, ClipboardCheck, MessageCircle, ShieldPlus } from '@lucide/astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import ConversionPanel from '../components/ConversionPanel.astro';
import FAQSection from '../components/FAQSection.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TrustStrip from '../components/TrustStrip.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { categories, getServicesByCategory, services, siteConfig, absoluteUrl } from '../data/services';

const title = 'MedicExpress | Servicios médicos a domicilio conectados con SMD Vital';
const description =
  'MedicExpress orienta solicitudes de servicios médicos a domicilio, enfermería, laboratorio y teleconsulta con agendamiento por WhatsApp.';

const homeSchema = {
  '@context': 'https://schema.org',
  '@type': 'MedicalBusiness',
  name: siteConfig.name,
  url: siteConfig.url,
  image: absoluteUrl('/img/screens/doctors.png'),
  logo: absoluteUrl(siteConfig.logoPath),
  telephone: siteConfig.phone,
  areaServed: {
    '@type': 'City',
    name: 'Bogotá'
  },
  sameAs: [siteConfig.mainBrandUrl]
};

const faqs = [
  {
    question: 'MedicExpress y SMD Vital son lo mismo?',
    answer:
      'MedicExpress funciona como canal satélite de captación y orientación. La prioridad comercial es dirigir solicitudes calificadas hacia los canales de atención de SMD Vital.'
  },
  {
    question: 'Puedo solicitar el servicio directamente por WhatsApp?',
    answer:
      'Sí. El canal de WhatsApp permite validar servicio, ubicación, horario, datos básicos del paciente y disponibilidad.'
  },
  {
    question: 'Atienden urgencias vitales?',
    answer:
      'No reemplazamos una ruta de urgencias. Ante dificultad respiratoria severa, dolor torácico intenso, pérdida de conciencia o sangrado abundante, se debe acudir a urgencias.'
  }
];
---

<BaseLayout title={title} description={description} jsonLd={homeSchema}>
  <section class="container grid min-h-[calc(100vh-80px)] gap-12 py-14 lg:grid-cols-[1fr_0.92fr] lg:items-center">
    <div>
      <h1 class="text-balance max-w-3xl text-5xl font-black tracking-tight text-slate-950 md:text-7xl">
        Servicios médicos a domicilio con respuesta clara y humana
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">
        MedicExpress convierte una búsqueda de salud en una conversación útil: entendemos la necesidad,
        validamos el servicio y orientamos el agendamiento hacia el canal adecuado de SMD Vital.
      </p>
      <p class="mt-4 inline-flex max-w-2xl rounded-full bg-indigo-50 px-4 py-2 text-sm font-black text-indigo-800 ring-1 ring-indigo-100">
        {siteConfig.referralMessage}
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <WhatsAppButton label="Agendar por WhatsApp" />
        <a class="btn-secondary" href="#servicios">
          <span>Explorar servicios</span>
          <ArrowRight size={18} stroke-width={2.4} />
        </a>
      </div>
      <div class="mt-8 grid max-w-2xl gap-3 sm:grid-cols-3">
        {['Orientacion inicial', 'Servicios en casa', 'Conexion SMD Vital'].map((item) => (
          <div class="flex items-center gap-2 text-sm font-bold text-slate-700">
            <CheckCircle2 class="text-indigo-700" size={18} stroke-width={2.4} />
            <span>{item}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="surface relative overflow-hidden rounded-[36px] p-6">
      <div class="absolute right-0 top-0 h-32 w-32 rounded-bl-[60px] bg-indigo-100"></div>
      <img
        src="/img/illustrations/hero.svg"
        alt="Equipo medico ilustrado para atencion domiciliaria"
        class="relative mx-auto aspect-[4/3] w-full max-w-[520px] object-contain"
        loading="eager"
      />
      <div class="relative grid gap-3 md:grid-cols-3">
        {[
          { icon: MessageCircle, label: 'WhatsApp', text: 'Datos basicos' },
          { icon: ClipboardCheck, label: 'Clasificación', text: 'Servicio y zona' },
          { icon: ShieldPlus, label: 'Atención', text: 'Paso responsable' }
        ].map(({ icon: Icon, label, text }) => (
          <div class="rounded-3xl bg-white p-4 shadow-lg shadow-slate-950/5">
            <Icon class="text-indigo-700" size={22} stroke-width={2.4} />
            <h2 class="mt-3 text-sm font-black text-slate-950">{label}</h2>
            <p class="mt-1 text-xs font-semibold text-slate-500">{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <TrustStrip />

  <section id="servicios" class="section">
    <div class="container">
      <div class="max-w-3xl">
        <p class="kicker">Servicios indexables</p>
        <h2 class="mt-3 text-4xl font-black tracking-tight text-slate-950 md:text-5xl">
          Las rutas actuales se conservan y se fortalecen
        </h2>
        <p class="mt-5 text-lg leading-8 text-slate-600">
          Cada pagina mantiene su URL para proteger la indexacion existente, pero gana mejor estructura,
          mejor conversión y un mensaje más claro para el paciente.
        </p>
      </div>

      <div class="mt-12 space-y-12">
        {
          categories.map((category) => (
            <section>
              <div class="mb-5 flex items-end justify-between gap-4">
                <h3 class="text-2xl font-black text-slate-950">{category}</h3>
                <span class="text-sm font-bold text-slate-500">{getServicesByCategory(category).length} paginas</span>
              </div>
              <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
                {getServicesByCategory(category).map((service) => (
                  <ServiceCard service={service} />
                ))}
              </div>
            </section>
          ))
        }
      </div>
    </div>
  </section>

  <section id="proceso" class="section bg-white">
    <div class="container grid gap-12 lg:grid-cols-[0.82fr_1fr] lg:items-start">
      <div>
        <p class="kicker">Proceso comercial</p>
        <h2 class="mt-3 text-4xl font-black tracking-tight text-slate-950 md:text-5xl">
          Menos friccion, mas solicitudes calificadas
        </h2>
        <p class="mt-5 text-lg leading-8 text-slate-600">
          El objetivo no es solo posicionar: es convertir tráfico en conversaciones que el equipo pueda cerrar.
          MedicExpress debe medir, orientar y transferir demanda hacia la operacion principal.
        </p>
      </div>
      <ol class="grid gap-4">
        {[
          'El usuario llega por búsqueda orgánica a una página específica.',
          'Encuentra una explicación clara, precio cuando aplica y alcance responsable.',
          'Inicia WhatsApp con mensaje prellenado desde MedicExpress.',
          'El equipo valida datos mínimos, disponibilidad y siguiente paso con SMD Vital.'
        ].map((step, index) => (
          <li class="surface flex gap-5 rounded-[28px] p-6">
            <span class="grid h-11 w-11 shrink-0 place-items-center rounded-full bg-indigo-700 text-sm font-black text-white">
              {index + 1}
            </span>
            <p class="pt-2 text-base font-bold leading-7 text-slate-800">{step}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <ConversionPanel />
  <FAQSection faqs={faqs} />
</BaseLayout>
