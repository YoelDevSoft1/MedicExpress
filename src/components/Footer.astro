---
import WhatsAppButton from './WhatsAppButton.astro';
import { categories, getServicesByCategory, getSmdReferralUrl, siteConfig } from '../data/services';
---

<footer class="border-t border-slate-200 bg-slate-950 text-white">
  <div class="container grid gap-10 py-12 lg:grid-cols-[1.1fr_1.8fr]">
    <div>
      <div class="flex items-center gap-3">
        <img
          src={siteConfig.logoPath}
          alt="Logo MedicExpress"
          width="52"
          height="52"
          class="h-13 w-13 shrink-0 object-contain"
          loading="lazy"
        />
        <div>
          <strong class="block text-lg font-black">MedicExpress</strong>
          <span class="text-sm text-slate-400">La atención será coordinada por SMD Vital Bogotá.</span>
        </div>
      </div>
      <p class="mt-5 max-w-md text-sm leading-7 text-slate-300">
        Orientamos solicitudes de servicios médicos, enfermería y laboratorio a domicilio con lenguaje claro,
        respeto por la privacidad del paciente y conexión directa con el equipo de atención de SMD Vital.
      </p>
      <div class="mt-6">
        <WhatsAppButton label="Hablar con un asesor" variant="primary" />
      </div>
    </div>

    <div class="grid gap-8 sm:grid-cols-3">
      {
        categories.map((category) => (
          <div>
            <h2 class="text-sm font-black text-white">{category}</h2>
            <ul class="mt-4 space-y-3 text-sm text-slate-400">
              {getServicesByCategory(category).slice(0, 7).map((service) => (
                <li>
                  <a class="transition hover:text-white" href={`/${service.slug}/`}>
                    {service.shortTitle}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="container flex flex-col gap-3 py-5 text-xs text-slate-500 md:flex-row md:items-center md:justify-between">
      <p>© {new Date().getFullYear()} MedicExpress. Dominio independiente conectado comercialmente con SMD Vital.</p>
      <a
        href={getSmdReferralUrl('/', 'footer_smd_vital')}
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-slate-200"
      >
        Sitio principal: SMD Vital Bogotá
      </a>
    </div>
  </div>
</footer>

