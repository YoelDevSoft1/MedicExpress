---
type FAQ = {
  question: string;
  answer: string;
};

type Props = {
  faqs: FAQ[];
  title?: string;
};

const { faqs, title = 'Preguntas frecuentes' } = Astro.props;
---

<section class="section bg-slate-50">
  <div class="container grid gap-10 lg:grid-cols-[0.7fr_1fr]">
    <div>
      <p class="kicker">Informacion clara</p>
      <h2 class="mt-3 text-3xl font-black tracking-tight text-slate-950 md:text-4xl">{title}</h2>
      <p class="mt-4 max-w-md text-base leading-7 text-slate-600">
        La prioridad es orientar bien al paciente, reducir fricción y escalar responsablemente si el caso supera el alcance domiciliario.
      </p>
    </div>
    <div class="space-y-4">
      {
        faqs.map((faq) => (
          <details class="group rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
            <summary class="cursor-pointer list-none text-base font-black text-slate-950">
              {faq.question}
            </summary>
            <p class="mt-3 text-sm leading-7 text-slate-600">{faq.answer}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>

